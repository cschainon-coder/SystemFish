# คัดลอกไฟล์นี้เป็น .env แล้วแก้ค่าตามเครื่องของคุณ
# (ไฟล์ .env จริงไม่ถูกเก็บใน git เพราะอาจมีข้อมูลลับ)
#
# ถ้าไม่มีไฟล์ .env เลย เว็บก็ยังรันได้ปกติ โดยใช้ค่า default = mock / port 3000

# โหมดข้อมูล: mock = ใช้ไฟล์ JSON ในเครื่อง | sheets = ใช้ Google Sheets จริง
DATA_SOURCE=mock

PORT=3000

# ===== ใช้เมื่อเปลี่ยนเป็น DATA_SOURCE=sheets เท่านั้น =====
# GOOGLE_APPLICATION_CREDENTIALS=./credentials.json
# SPREADSHEET_ID=
# CACHE_TTL=300
